<launch>
  <!-- =========================================================
       can_driver 启动文件
       启动顺序：加载参数 → 启动节点 → 加载控制器
       ========================================================= -->

  <!-- 是否加载 ros_control 控制器（默认 false：直通调试模式） -->
  <arg name="use_controllers" default="false"/>

  <!-- 1. 加载硬件参数（关节映射、控制频率） -->
  <rosparam file="$(find can_driver)/config/can_driver.yaml" command="load"/>

  <!-- 2. 加载控制器参数（仅在 use_controllers=true 时加载） -->
  <rosparam file="$(find can_driver)/config/ros_controllers.yaml" command="load"
            if="$(arg use_controllers)"/>

  <!-- 3. 启动 can_driver_node（包含 CanDriverHW + controller_manager 主循环） -->
  <node pkg="can_driver" type="can_driver_node" name="can_driver_node" output="screen"/>

  <!-- 4. 加载并启动控制器（仅在 use_controllers=true 时启动） -->
  <node pkg="controller_manager" type="spawner" name="controller_spawner"
        args="joint_state_controller" if="$(arg use_controllers)"/>

  <!-- 有 URDF 后取消注释：
  <node pkg="controller_manager" type="spawner" name="controller_spawner_full"
        args="arm_controller wheel_controller" if="$(arg use_controllers)"/>
  -->

</launch>
